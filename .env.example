# Database — defaults to the docker-compose Postgres service.
# For a quick local run without Docker, set: DATABASE_URL=sqlite:///./projecto2.db
DATABASE_URL=postgresql+psycopg://o2_admin:o2_secret@localhost:5544/projecto2

# Auth
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS — the Next.js frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# Workspace — only emails on this domain may sign up or be invited
WORKSPACE_EMAIL_DOMAIN=optiminastic.com

# Uploads
UPLOAD_DIR=./uploads

# Email — team invitations. Leave SMTP_HOST blank to disable sending; the Circle
# page then shows a copy-able invite link instead. For Gmail, use an App Password
# (not your normal password) and SMTP_HOST=smtp.gmail.com, SMTP_PORT=587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@optiminastic.com
SMTP_FROM_NAME=Project O2
SMTP_REPLY_TO=
SMTP_USE_TLS=true
INVITE_EXPIRE_HOURS=168
